# MongoDB Atlas — use a demo-scoped user in production
ATLAS_URI=

# LLM + embeddings (Railway only — never on Vercel)
OPENAI_API_KEY=
VOYAGE_API_KEY=

# Optional Grove gateway (instead of direct OpenAI)
# GROVE_API_KEY=
# GROVE_BASE_URL=
# GROVE_MODEL=gpt-5.5

# Comma-separated browser origins allowed to call the API (CORS)
ALLOWED_ORIGINS=http://localhost:3000

# Shared secret between Next.js proxy (Vercel) and this API (Railway).
# Leave empty for local dev without auth.
BACKEND_API_KEY=

# Enable local-first-run setup wizard at http://localhost:3000/setup
ALLOW_SETUP=true

# Customer kiosk mode — simulator runs only during explicit browser sessions
# SIM_SESSION_MODE=true
# SIM_LEASE_TIMEOUT_SEC=90
