# NextAuth — generate with: openssl rand -base64 32 (or let the setup wizard create this)
AUTH_SECRET=

# Dashboard login — set via setup wizard or manually
DEMO_USER=
DEMO_USER_PASSWORD=

# FastAPI backend. Server-side only — never NEXT_PUBLIC_.
API_URL=http://localhost:8000
BACKEND_API_KEY=

# Enable local-first-run setup wizard (disabled on Vercel)
ALLOW_SETUP=true

# Customer kiosk mode — Start live demo session on Fleet/Alerts (set on Vercel for handoff)
# NEXT_PUBLIC_SIM_SESSION_MODE=true
# NEXT_PUBLIC_SIM_IDLE_TIMEOUT_SEC=180

# Playwright e2e — npm run test:e2e (see e2e/*.spec.ts)
# E2E_BASE_URL=https://pulse-bmc.vercel.app
# E2E_DEMO_USER=
# E2E_DEMO_PASSWORD=
